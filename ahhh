#!/usr/bin/env bash
set -euo pipefail

# Use realpath to ensure the real path to ahhh is used even when it is invoked
# from a symlink.
CTX_DIR="$(dirname "$(realpath "$0")")/image"
readonly CTX_DIR
readonly KEYCHAIN_SERVICE='ahhh-claude-oauth-token'
export CLAUDE_CODE_OAUTH_TOKEN
claude_md_glbl=''  # set by --claude-md; empty means the host's global CLAUDE.md
codex_md_glbl=''   # set by --codex-md; empty means the host's global AGENTS.md

usage() {
  cat >&2 <<EOF
usage: ahhh build [<options>]
       ahhh run   [<options>] <env-name> [command...]


build  (re)build the image
           --claude             build the Claude image (default)
           --codex              build the Codex image
           --update             refreshes the base image and packages
           --claude-md <file>   global CLAUDE.md (default: ~/.claude/CLAUDE.md)
           --codex-md  <file>   global AGENTS.md (default: ~/.codex/AGENTS.md)

run    run a command in an ephemeral environment
           --claude             use Claude (default)
           --codex              use Codex
           --allow-non-git      allow running outside a Git repository
           --read-only          mounts the current directory read-only
           --memory    <size>   RAM for the env (default: 4G)
           --cpus      <count>  CPUs for the env

EOF
  exit 1
}

image_for_agent() {
  echo "ahhh-$1"
}

build_image() {
  local agent="$1"
  shift
  local img_tag
  img_tag="$(image_for_agent "$agent")"

  # Copy the host's global agent configs into the image's $HOME seed.
  local md_glbl
  local md_copy
  case "$agent" in
    claude)
      if [ -z "$claude_md_glbl" ]; then
        claude_md_glbl="$HOME/.claude/CLAUDE.md"
        [ -f "$claude_md_glbl" ] || claude_md_glbl=/dev/null
      fi
      md_glbl="$claude_md_glbl"
      md_copy="$CTX_DIR/home/.claude/HOST_CLAUDE.md"
      ;;
    codex)
      if [ -z "$codex_md_glbl" ]; then
        codex_md_glbl="$HOME/.codex/AGENTS.md"
        [ -f "$codex_md_glbl" ] || codex_md_glbl=/dev/null
      fi
      md_glbl="$codex_md_glbl"
      md_copy="$CTX_DIR/home/.codex/HOST_AGENTS.md"
      ;;
    *)
      >&2 echo "bug: unknown agent '${agent}'"
      exit 2
      ;;
  esac
  # Avoid potential symlink shenanigans and rm before copying.
  rm -f "$md_copy"
  install -m 644 "$md_glbl" "$md_copy"

  container build "$@" --target "$agent" -t "$img_tag" \
    --file "$CTX_DIR/Containerfile" "$CTX_DIR"
}

cmd_build() {
  local agent=''
  local update=''

  while [ $# -gt 0 ]; do
    case "$1" in
      --claude|--codex)
        [ -z "$agent" ] || usage
        agent="${1#--}"
        ;;
      --update)
        update='true'
        ;;
      --claude-md)
        [ $# -ge 2 ] || usage
        claude_md_glbl="$2"
        shift
        ;;
      --codex-md)
        [ $# -ge 2 ] || usage
        codex_md_glbl="$2"
        shift
        ;;
      *)
        usage
        ;;
    esac
    shift
  done
  agent="${agent:-claude}"
  # --no-cache reruns every step; --pull stops FROM resolving to a stale
  # locally cached base image.
  [ "$update" != 'true' ] || set -- --no-cache --pull
  container system start
  build_image "$agent" "$@"
}

cleanup() {
  container volume delete "$env_name-home" "$env_name-nix" > /dev/null || :
  container network delete "$env_name" > /dev/null || :
}

cmd_run() {
  local agent=''
  local allow_non_git=''
  local memory='4G'
  local cpus=''
  local read_only=''

  while [ $# -gt 0 ]; do
    case "$1" in
      --claude|--codex)
        [ -z "$agent" ] || usage
        agent="${1#--}"
        ;;
      --allow-non-git)
        allow_non_git='true'
        ;;
      --read-only)
        read_only='true'
        ;;
      --memory)
        [ $# -ge 2 ] || usage
        memory="$2"
        shift
        ;;
      --cpus)
        [ $# -ge 2 ] || usage
        cpus="$2"
        shift
        ;;
      -*)
        usage
        ;;
      *)
        break
        ;;
    esac
    shift
  done
  agent="${agent:-claude}"
  [ $# -ge 1 ] || usage
  # Not a local var so that the trap can reference it.
  env_name="ahhh-$1"
  shift
  if [ $# -eq 0 ]; then
    case "$agent" in
      claude)
        set -- claude --dangerously-skip-permissions
        ;;
      codex)
        set -- codex --dangerously-bypass-approvals-and-sandbox
        ;;
      *)
        >&2 echo "bug: unknown agent '${agent}'"
        exit 2
        ;;
    esac
  fi

  # Validate preconditions:
  # - Current dir is a git repo unless explicitly allowed otherwise.
  if [ "$allow_non_git" != 'true' ]; then
    git rev-parse --show-toplevel > /dev/null
  fi

  case "$agent" in
    claude)
      CLAUDE_CODE_OAUTH_TOKEN="$(
        security find-generic-password -s "$KEYCHAIN_SERVICE" -w
      )" || {
        cat >&2 <<EOF
No Claude OAuth token in the Keychain. One-time setup:
  1. Run: claude setup-token
  2. Store the printed token:
     security add-generic-password -U -s $KEYCHAIN_SERVICE -a "\$USER" -w
EOF
        exit 1
      }
      ;;
    codex)
      ;;
  esac

  container system start
  local img_tag
  img_tag="$(image_for_agent "$agent")"
  container image inspect "$img_tag" > /dev/null 2>&1 || build_image "$agent"
  # Trap before creating so a partial failure still cleans up.
  trap cleanup EXIT
  container network create "$env_name"
  container volume create -s 64G "$env_name-home"
  container volume create -s 64G "$env_name-nix"
  # Fresh volumes are root-owned ext4 with a lost+found dir: rm it so the
  # entrypoint's empty-$HOME check holds, and chown for the agent uid.
  container run --rm \
    --network "$env_name" \
    --uid 0 --gid 0 \
    --cap-drop ALL \
    --cap-add CHOWN \
    --read-only \
    --entrypoint /bin/sh \
    --volume "$env_name-home:/home/agent" \
    --volume "$env_name-nix:/nix" \
    "$img_tag" -euc 'rm -rf /home/agent/lost+found /nix/lost+found && chown 1000:1000 /home/agent /nix'
  # Effective (not --global) config so includeIf/local overrides apply.
  local git_name
  git_name="$(git config user.name)"
  local git_email
  git_email="$(git config user.email)"
  local -a run_args
  run_args=(
    --rm -it
    --name "$env_name"
    --network "$env_name"
    --uid 1000 --gid 1000
    --cap-drop ALL
    --read-only
    --tmpfs /tmp
    --volume "$env_name-home:/home/agent"
    --volume "$env_name-nix:/nix"
    --init
    --memory "$memory"
    --mount "source=$PWD,target=/workspace${read_only:+,readonly}"
    --cwd /workspace
    # Forward terminal env vars needed to make it look good.
    --env TERM
    --env COLORTERM
    --env TERM_PROGRAM
    # Committer vars too: git refuses to commit knowing only the author.
    --env GIT_AUTHOR_NAME="$git_name"
    --env GIT_AUTHOR_EMAIL="$git_email"
    --env GIT_COMMITTER_NAME="$git_name"
    --env GIT_COMMITTER_EMAIL="$git_email"
  )
  [ -z "$cpus" ] || run_args+=(--cpus "$cpus")
  case "$agent" in
    claude)
      run_args+=(
        --env CLAUDE_CODE_OAUTH_TOKEN
        --env ANTHROPIC_MODEL
        --env CLAUDE_CODE_EFFORT_LEVEL
        --env CLAUDE_CODE_SUBAGENT_MODEL
      )
      ;;
    codex)
      ;;
  esac
  container run "${run_args[@]}" "$img_tag" "$@"
}

case "${1-}" in
  build)
    shift
    cmd_build "$@"
    ;;
  run)
    shift
    cmd_run "$@"
    ;;
  *)
    usage
    ;;
esac
