#!/usr/bin/env bash
set -euo pipefail

env_name="ahhh-${1:?usage: ahhh <env-name> [command...]}"; shift
[ $# -gt 0 ] || set -- claude --dangerously-skip-permissions
dir_name="$(dirname "$0")"
con_file="$dir_name/Containerfile"
img_tag="ahhh-base"
keychain_service="ahhh-claude-oauth-token"
oauth_token="$(security find-generic-password -s "$keychain_service" -w)" || {
  cat >&2 <<EOF
No Claude OAuth token in the Keychain. One-time setup:
  1. Run: claude setup-token
  2. Store the printed token:
     security add-generic-password -U -s $keychain_service -a "\$USER" -w
EOF
  exit 1
}

container system start
container network create "$env_name"
trap 'container network delete "$env_name" > /dev/null' EXIT
container build -t "$img_tag" --file "$con_file" "$dir_name"
run_args=(
  --rm -it
  --name "$env_name"
  --network "$env_name"
  --uid 1000 --gid 1000
  --cap-drop ALL
  --read-only
  --tmpfs /tmp
  --tmpfs /home/agent
  --init
  --memory 4G
  --volume "$(pwd)":/workspace
  --cwd /workspace
  --env CLAUDE_CODE_OAUTH_TOKEN="$oauth_token"
  --env ANTHROPIC_MODEL
  --env CLAUDE_CODE_EFFORT_LEVEL
  --env CLAUDE_CODE_SUBAGENT_MODEL
  # Effective (not --global) config so includeIf/local overrides apply;
  # committer vars too: git refuses to commit knowing only the author.
  --env GIT_AUTHOR_NAME="$(git config user.name)"
  --env GIT_AUTHOR_EMAIL="$(git config user.email)"
  --env GIT_COMMITTER_NAME="$(git config user.name)"
  --env GIT_COMMITTER_EMAIL="$(git config user.email)"
)
container run "${run_args[@]}" "$img_tag" "$@"
