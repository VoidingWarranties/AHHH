#!/usr/bin/env sh
set -eu

[ -n "$(ls -A "$HOME")" ] || cp -R /usr/share/ahhh/. "$HOME"
# Kill memory hogs early: with no swap the guest livelocks before kernel OOM.
# --avoid: prefer the agent's children; killing the agent ends the container.
earlyoom -r 0 --avoid 'claude|codex' >/tmp/earlyoom.log 2>&1 &
exec "$@"
